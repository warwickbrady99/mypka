{
  "name": "mypka-cockpit",
  "private": true,
  "version": "1.2.1",
  "description": "myPKA Cockpit — a navigable, wikilink-aware viewer over your myPKA. Reads mypka.db read-only; Fleeting Notes is the only write surface (PKM/Fleeting Notes/).",
  "type": "module",
  "scripts": {
    "install:all": "npm install && npm --prefix web install",
    "build": "npm --prefix web run build",
    "build:web": "npm --prefix web run build",
    "start": "node server/server.js",
    "server": "node server/server.js",
    "dev:server": "node server/server.js",
    "dev:web": "npm --prefix web run dev",
    "serve": "npm run build && node server/server.js",
    "serve:lan": "npm run build && COCKPIT_BIND_LAN=1 node server/server.js",
    "set-pin": "node server/set-pin.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "express": "^4.21.2",
    "imapflow": "^1.4.1",
    "node-ical": "^0.26.1"
  }
}
