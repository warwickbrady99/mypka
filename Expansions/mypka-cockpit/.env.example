# myPKA Cockpit — environment template (reference copy).
#
# IMPORTANT: at runtime the cockpit reads secrets from the SCAFFOLD-ROOT
# file `Team Knowledge/.env` (chmod 600, gitignored), NOT from this folder.
# This file ships only so the package is self-documenting. To configure:
#   1. cp this file's keys into `<scaffold-root>/Team Knowledge/.env`
#   2. fill in the values you need (leave a key blank to disable its connector)
#   3. restart the cockpit
# The real `Team Knowledge/.env` is gitignored and NEVER ships. Keep secrets there only.

# --- Scaffold root resolution ------------------------------------------------
# Where the cockpit looks for your myPKA (mypka.db, PKM/, Team Knowledge/.env).
# Resolution order (server/repoRoot.js), first match wins:
#   1. MYPKA_ROOT below, if set and pointing at a real directory.
#   2. An upward search from the cockpit folder for the scaffold fingerprint
#      (a directory containing BOTH `AGENTS.md` and `PKM/`); a generated
#      `mypka.db` is accepted as a secondary marker.
#   3. Fallback: three levels up — the standard Expansions/mypka-cockpit/ layout.
# Leave UNSET for a normal install (auto-detection just works). Set it only for a
# relocated cockpit or a scaffold on another volume.
MYPKA_ROOT=

# --- External connectors (OFF by default — inert example source) -------------
# The bundled connectors (Todoist / ClickUp / iCal / IMAP-starred) ship as DISABLED
# example source so your LLM can study and adapt the pattern. They DO NOT load on a
# fresh install. Master gate (default off):
#   1 → admit the example connectors; each still activates only when its key resolves
#   (unset / anything else) → engine dormant, no connector module loaded
CONNECTORS_ENABLED=

# Read-only task/PM/calendar sources. Each activates only when CONNECTORS_ENABLED=1
# AND its key(s) below resolve.
# Todoist personal API token (Settings > Integrations > Developer). ~40-char token.
TODOIST_API_TOKEN=

# Linear personal API key (Settings > API > Personal API keys). Starts with `lin_api_`.
LINEAR_API_KEY=

# ClickUp personal API token (Settings > Apps).
CLICKUP_API_KEY=
# ClickUp workspace (team) id — not a secret. Co-located with the token.
CLICKUP_TEAM_ID=
# OPTIONAL ClickUp assignee override. Leave UNSET — the connector derives the
# connected user's id from the token (GET /user). Set only to watch a DIFFERENT
# assignee than the token owner.
CLICKUP_ASSIGNEE_ID=

# Calendar subscription URL (.ics / iCal feed). Use the SECRET/private address.
CALENDAR_ICAL_URL=

# IMAP "starred email" connector (read-only). Works with Gmail (app password),
# Fastmail, iCloud, GMX, any IMAP host.
EMAIL_IMAP_HOST=
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=

# --- Health module example heuristics (OFF / empty by default) ---------------
# The optional health pack ships generic, EMPTY-by-default heuristics so it shows
# YOUR data, never the author's. Fill these in to adapt them to your own notes.
# Comma-separated linked_my_life slugs that mark a task as personal (health/family):
PERSONAL_LIFE_LINKS=
# Comma-separated keywords (word-boundary matched) that mark a task as personal:
PERSONAL_TASK_HINTS=
# The `assignee` frontmatter value that marks a task as yours (for keyword matches).
# Empty → keyword-only matches never qualify (only link matches do).
PERSONAL_TASK_OWNER=
# Substring matched against deliverable slugs to find your nutrition-plan note.
# Default 'EXAMPLE_nutrition_plan' matches nothing (pointer stays inert).
NUTRITION_PLAN_SLUG=
# Exam→note link hints as a JSON array, e.g.
#   EXAM_NOTE_HINTS=[{"pattern":"checkup|physical","slug":"annual-checkup"}]
# Empty → no exam links attached (still honest, just Sheet-only).
EXAM_NOTE_HINTS=
# Comma-separated Topic slugs the Mind section spotlights (empty → none).
MIND_TOPIC_SLUGS=
# Per-instance tone map for the Mind "patterns" cards, as a JSON object keyed by
# Topic slug (the client-side partner of MIND_TOPIC_SLUGS above). Build-time only,
# so it MUST be prefixed VITE_ to reach the web bundle. Empty → every slug renders
# neutral (calm default). Example:
#   VITE_MIND_VALENCE_MAP={"my-pattern-slug":{"tone":"watch","label":"watch"}}
VITE_MIND_VALENCE_MAP=
# Comma-separated habit-note slugs the Planned section spotlights (empty → none).
HABIT_SLUGS=

# --- Cockpit runtime toggles (declared in expansion.yaml; all optional) ------
# TCP port the cockpit binds. Default 4317.
PORT=

# The LLM CLI the "Discuss with AI" / wire-assistant / quick-launch-terminal
# buttons launch in a new Terminal. Default `claude`. Set to your CLI if you use a
# different one, e.g. COCKPIT_LLM_CMD=codex  or  COCKPIT_LLM_CMD=gemini.
# Must be a bare command name or a path (letters, digits, _ . - / only — no spaces
# or shell metacharacters); an invalid value falls back to `claude`.
# NOTE: the optional Discuss model picker (--model opus|sonnet|haiku) is
# Claude-specific — the cockpit only adds --model when this command is `claude`.
# Other CLIs receive just the prompt (no Claude-only flags).
COCKPIT_LLM_CMD=

# 1 enables the Fleeting Notes editor + whiteboards (writes only under
# PKM/Fleeting Notes/). Launcher defaults to 1; set 0 for a read-only cockpit.
WORKBENCH_WRITE_ENABLED=

# 1 enables saving the day-planner's LOCAL plan layout to mypka-cockpit.db
# (like browser storage — never the vault, never an external tool). Default 1.
PLAN_WRITE_ENABLED=

# 1 binds 0.0.0.0 so your own phone/tablet on your own network can reach the
# cockpit. HARD-GATED on a configured PIN — refuses to start without one.
COCKPIT_BIND_LAN=

# scrypt hash of the access PIN (NEVER the cleartext PIN). Set with `npm run set-pin`.
COCKPIT_PIN_HASH=

# 1 serves HTTPS and marks the session cookie Secure. Needs the cert + key below.
COCKPIT_USE_TLS=

# Path to a TLS certificate (only with COCKPIT_USE_TLS=1).
COCKPIT_TLS_CERT=

# Path to the TLS private key (only with COCKPIT_USE_TLS=1).
COCKPIT_TLS_KEY=
